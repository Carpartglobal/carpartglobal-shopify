{% comment %}
  Vehicle slot (#cm-garage) + search bar in one container.
  Called from header-advanced with: {% render 'header-vehicle-search-bar', block: block, section_settings: settings %}
{% endcomment %}
<div class="header-vehicle-search-bar" id="header-vehicle-search-bar">
  <div class="header-vehicle-slot" id="header-vehicle-slot">
    <div id="cm-garage"></div>
  </div>
  {%- if block.settings.show_search -%}
  <div class="header__search header-advanced-search-inline clearfix{% if block.settings.show_box_shadow %} show-box-shadow{% endif %}" style="--bg-search-color: {{ block.settings.bg_search_color }}; --search-color: {{ block.settings.search_color }}; --search-icon-color: {{ block.settings.search_icon_color }}; --search-icon-bg: {% if block.settings.search_icon_gradient != blank %}{{ block.settings.search_icon_gradient }}{% else %}{{ block.settings.search_icon_bg }}{% endif %}; --search-border-radius: {{ block.settings.search_border_radius }}px">
    <details-modal class="header__iconItem header__search">
      {%- if section_settings.show_quick_search -%}
        <predictive-search class="search-modal__form" data-loading-text="{{ 'accessibility.loading' | t }}" data-product-to-show="{{ section_settings.quick_search_to_show }}">
      {%- endif -%}
      <details class="search_details">
        <summary class="header__search-full" aria-haspopup="dialog" aria-label="{{ 'general.search.search' | t }}">
          <button type="button" class="header-search-close" aria-label="{{ 'general.common.close' | t }}">
            {% render 'icon-close' %}
          </button>
          <form action="{{ routes.search_url }}" method="get" role="search" class="search search-modal__form">
            <div class="field">
              <input class="search__input field__input form-input-placeholder" id="Search-In-Modal-Advanced" type="search" name="q" value="{{ search.terms | escape }}" placeholder="{{ 'general.search.search_the_store' | t }}" autocomplete="off" {%- if section_settings.show_quick_search -%}role="combobox" aria-expanded="false" aria-owns="predictive-search-results-list" aria-controls="predictive-search-results-list" aria-haspopup="listbox" aria-autocomplete="list" autocorrect="off" autocomplete="off" autocapitalize="off" spellcheck="false"{%- endif -%}>
              <input type="hidden" name="options[prefix]" value="last">
              <input type="hidden" name="type" value="product">
              <label class="field__label hiddenLabels" for="Search-In-Modal-Advanced">{{ 'general.search.search_the_store' | t }}</label>
              <button class="button search__button field__button focus-inset" aria-label="{{ 'general.search.search' | t }}">{% render 'icon-search-02' %}</button>
            </div>
            {%- if section_settings.show_quick_search -%}
              {%- if section_settings.show_search_trending or section_settings.show_search_product -%}
                {%- render 'quick-searching-trending-products', sectionId: 'advanced-list-result' -%}
              {%- endif -%}
              {%- render 'predictive-search-results' -%}
            {%- endif -%}
          </form>
        </summary>
        <div class="search-modal modal__content{% if section_settings.show_quick_search %} quickSearch{% endif %}" role="dialog" aria-modal="true" aria-label="{{ 'general.search.search' | t }}">
          {%- if section_settings.show_quick_search -%}
            {% render 'halo-quick-search', sectionId: 'quick-advanced-list-result' %}
          {%- endif -%}
        </div>
      </details>
      {%- if section_settings.show_quick_search -%}
        </predictive-search>
      {%- endif -%}
    </details-modal>
  </div>
  {%- endif -%}
</div>