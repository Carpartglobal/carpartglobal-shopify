ble_btn_show_more":false,"maximum_des_to_show":300}},"custom_WE6UTF":{"type":"custom","settings":{"open_tab_mobile":false,"title":"✮ Reviews","type":"all","content":"<style>\n  .carpart-info-section {\n    background-color: #ffffff;\n   \n    padding: 0px;\n    font-family: 'Helvetica Neue', sans-serif;\n    color: #222;\n  }\n\n  .carpart-info-container {\n    max-width: 1200px;\n    margin: auto;\n  }\n\n  .carpart-info-title {\n    font-size: 20px;\n    font-weight: 700;\n    margin-bottom: 30px;\n    color: #004aad;\n    text-align: center;\n  }\n\n  .carpart-info-columns {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 30px;\n    justify-content: space-between;\n  }\n\n  .carpart-info-box {\n    flex: 1 1 300px;\n    background-color: #f8f9fa;\n    border: 1px solid #dcdcdc;\n    padding: 25px;\n    border-radius: 12px;\n    box-shadow: 0 3px 6px rgba(0,0,0,0.05);\n    transition: all 0.3s ease;\n  }\n\n  .carpart-info-box:hover {\n    box-shadow: 0 6px 12px rgba(0,0,0,0.1);\n  }\n\n  .carpart-info-box h3 {\n    font-size: 18px;\n    color: #111;\n    margin-bottom: 15px;\n    display: flex;\n    align-items: center;\n    gap: 10px;\n  }\n\n  .carpart-info-box p {\n    font-size: 14px;\n    line-height: 1.6;\n    margin: 0;\n    color: #555;\n  }\n\n  .carpart-info-box ul {\n    margin: 10px 0 0 20px;\n    padding: 0;\n  }\n\n  .carpart-info-box ul li {\n    list-style-type: disc;\n    font-size: 15px;\n    color: #555;\n    margin-bottom: 6px;\n  }\n\n  .carpart-info-box a {\n    color: #004aad;\n    text-decoration: none;\n  }\n\n  .carpart-info-box a:hover {\n    text-decoration: underline;\n  }\n<\/style>\n\n<div class=\"carpart-info-section\">\n  <div class=\"carpart-info-container\">\n \n    <div class=\"carpart-info-columns\">\n\n      <div class=\"carpart-info-box\">\n        <h3>🔧 Guaranteed Fit<\/h3>\n        <p>\n          Every part is carefully matched to your vehicle's make, model, and year to ensure a perfect fit. Unsure about compatibility? <a href=\"mailto:info@carpartglobal.com\">Contact our support<\/a>.\n        <\/p>\n      <\/div>\n\n      <div class=\"carpart-info-box\">\n        <h3>🚚 Fast Canada-Wide Shipping<\/h3>\n        <p>\n          We ship from within Canada, so you can expect your parts in 2–5 business days. Orders are processed within 24 hours.\n        <\/p>\n      <\/div>\n\n      <div class=\"carpart-info-box\">\n        <h3>🛠️ OEM & Aftermarket Quality<\/h3>\n        <p>\n          We offer both OEM and premium aftermarket parts. All items meet or exceed industry standards for performance and durability.\n        <\/p>\n      <\/div>\n\n      <div class=\"carpart-info-box\">\n        <h3>💬 Expert Support<\/h3>\n        <p>\n          Our team is here to help — whether it’s finding the right part or helping with installation. Reach out anytime via email or chat.\n        <\/p>\n      <\/div>\n\n      <div class=\"carpart-info-box\">\n        <h3>🔄 Easy Returns<\/h3>\n        <p>\n          Not happy with your purchase? We offer hassle-free returns within 30 days — no restocking fees, no stress.\n        <\/p>\n      <\/div>\n\n    <\/div>\n  <\/div>\n<\/div>","product_custom_source":"dynamic","product_tab_key_metafield":"","enable_btn_show_more":false,"maximum_des_to_show":300}},"3d9ea84d-5527-4bce-abe6-5debef3ec955":{"type":"custom","settings":{"open_tab_mobile":false,"title":"📦 Order Verification","type":"all","content":"<style>\n.cpg-tab-box {\n  border: 1px solid #e5e5e5;\n  border-radius: 6px;\n  padding: 18px;\n  background: #fafafa;\n  font-size: 14px;\n  line-height: 1.6;\n}\n.cpg-tab-box h3 {\n  margin-top: 0;\n  font-size: 18px;\n}\n.cpg-tab-box ul {\n  padding-left: 18px;\n}\n.cpg-tab-box a {\n  color: #0a58ca;\n  text-decoration: underline;\n}\n.cpg-note {\n  background: #fff;\n  border-left: 4px solid #0a58ca;\n  padding: 12px;\n  margin-top: 15px;\n}\n<\/style>\n\n<div class=\"cpg-tab-box\">\n  <h3>Shipping & Order Verification<\/h3>\n\n  <p>\n    To ensure accuracy and prevent incorrect orders, all purchases go through a\n    manual verification process before shipment.\n  <\/p>\n\n  <ul>\n    <li>Orders are reviewed for <strong>vehicle fitment<\/strong> and product accuracy<\/li>\n    <li>Inventory and pricing are validated with our suppliers<\/li>\n    <li>Some items may require additional processing time<\/li>\n    <li>Orders typically ship within <strong>1–3 business days<\/strong> after verification<\/li>\n  <\/ul>\n\n  <div class=\"cpg-note\">\n    <strong>Need it urgently or unsure about compatibility?<\/strong><br>\n    Please contact our support team before placing your order.<br>\n    👉 <a href=\"https:\/\/carpartglobal.com\/pages\/contact\" target=\"_blank\">Contact Support<\/a>\n  <\/div>\n\n  <p>\n    Verifying orders before shipping helps us reduce delays, prevent returns,\n    and ensure you receive the correct part the first time.\n  <\/p>\n<\/div>","product_custom_source":"dynamic","product_tab_key_metafield":"","enable_btn_show_more":false,"maximum_des_to_show":300}},"19ab1d9f-74b2-4c76-bf2e-1bc749e5c2a3":{"type":"share","settings":{"show_share":true,"share_layout":"2","spacing_top":0,"spacing_bottom":0}},"a86220cf-8641-4e06-87d3-b5ffa195501b":{"type":"custom_information","settings":{"icon":"<svg aria-hidden=\"true\" focusable=\"false\" data-prefix=\"fal\" data-icon=\"shipping-fast\" role=\"img\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\" viewbox=\"0 0 640 512\"><path fill=\"currentColor\" d=\"M280 192c4.4 0 8-3.6 8-8v-16c0-4.4-3.6-8-8-8H40c-4.4 0-8 3.6-8 8v16c0 4.4 3.6 8 8 8h240zm352 192h-24V275.9c0-16.8-6.8-33.3-18.8-45.2l-83.9-83.9c-11.8-12-28.3-18.8-45.2-18.8H416V78.6c0-25.7-22.2-46.6-49.4-46.6H113.4C86.2 32 64 52.9 64 78.6V96H8c-4.4 0-8 3.6-8 8v16c0 4.4 3.6 8 8 8h240c4.4 0 8-3.6 8-8v-16c0-4.4-3.6-8-8-8H96V78.6c0-8.1 7.8-14.6 17.4-14.6h253.2c9.6 0 17.4 6.5 17.4 14.6V384H207.6C193 364.7 170 352 144 352c-18.1 0-34.6 6.2-48 16.4V288H64v144c0 44.2 35.8 80 80 80s80-35.8 80-80c0-5.5-.6-10.8-1.6-16h195.2c-1.1 5.2-