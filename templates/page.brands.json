    "custom_liquid_8kpykR": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Final Call-to-Action Banner</title>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap\" rel=\"stylesheet\">\n    <style>\n        \n        /* Define the exact custom red color */\n        .cpg-red-bg { background-color: #e5002b; }\n        .cpg-red-text { color: #e5002b; }\n        .cpg-red-border { border-color: #e5002b; }\n\n        /* Custom class for max width and center alignment */\n        .list-container-1200 {\n            width: 100%;\n            max-width: 1200px;\n            margin-left: auto;\n            margin-right: auto;\n            padding-left: 1.5rem; /* Increased padding for better mobile spacing */\n            padding-right: 1.5rem;\n        }\n\n        /* Base button styling */\n        .cta-button {\n            display: inline-flex;\n            align-items: center;\n            justify-content: center;\n            padding: 0.75rem 2rem; /* Adjusted padding for better button height */\n            font-weight: 600; /* Semi-bold */\n            border-radius: 0.75rem; /* Rounded-xl */\n            transition: all 0.3s ease;\n            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);\n            font-size: 0.875rem; /* 14px minimum for buttons */\n        }\n        \n        /* Secondary Button Styling for Red Background */\n        .secondary-btn {\n            border: 2px solid white;\n            color: white;\n            background-color: transparent;\n        }\n        .secondary-btn:hover {\n            background-color: white;\n            color: #e5002b; /* Text becomes red on hover */\n            transform: translateY(-2px);\n        }\n.buttn {\n    padding: 15px 30px;\n    font-size: 16px !important;\nfont-weight: 500;\n}\n.pcl {\nfont-size: 15px;\nmax-width: 700px;\n}\n    </style>\n</head>\n<body>\n    \n    <!-- SECTION: Final CTA Banner (Contact or Shop) - Primary Red Background -->\n    <div class=\"cpg-red-bg py-16\">\n        <div class=\"list-container-1200 flex flex-col items-center text-center\">\n            \n            <!-- Heading: Text Size: 32px - 36px (appropriate for main heading) -->\n            <h3 class=\"text-3xl md:text-4xl font-extrabold text-white mb-4\">\n                Need Assistance Finding the Right Part?\n            </h3>\n            \n            <!-- Paragraph Text: Text Size: 16px (text-base, >14px minimum) -->\n            <p class=\"pcl text-red-100 mb-10 max-w-3xl\">\n                Contact our highly-trained experts for personalized advice, or jump straight into browsing our entire inventory. We're here to help you get the exact automotive part you need.\n            </p>\n            \n            <div class=\"flex flex-col sm:flex-row space-y-4 sm:space-y-0 sm:space-x-8\">\n                \n                <!-- CTA Button 1: Contact Us (Primary White Button) - Text Size: 14px -->\n                <a href=\"https://carpartglobal.com/pages/contact\" class=\" buttn cta-button text-white bg-white hover:bg-gray-100 text-cpg-red\">\n                    <svg class=\"w-5 h-5 mr-2\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" xmlns=\"http://www.w3.org/2000/svg\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498A1 1 0 0121 15.72V19a2 2 0 01-2 2H5a2 2 0 01-2-2z\"></path></svg>\n                    Contact Our Experts\n                </a>\n                \n                <!-- CTA Button 2: See the Shop (Secondary Outline Button) - Text Size: 14px -->\n                <a href=\"https://carpartglobal.com/products/\" class=\"buttn cta-button secondary-btn\">\n                    <svg class=\"w-5 h-5 mr-2\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" xmlns=\"http://www.w3.org/2000/svg\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z\"></path></svg>\n                    See Our Full Shop\n                </a>\n            </div>\n        </div>\n    </div>\n    <!-- END OF SECTION -->\n\n</body>\n</html>"
      }
    },
