    "custom_liquid_W9L4Li": {
      "type": "custom-liquid",
      "disabled": true,
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Featured Auto Parts Brands Directory</title>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap\" rel=\"stylesheet\">\n    <style>\n       \n        .text-cpg-red { color: #e5002b; }\n        .bg-cpg-red { background-color: #e5002b; }\n        \n        /* Custom class for 1000px width and center alignment */\n        .list-container-1000 {\n            width: 100%;\n            max-width: 1000px; /* Enforces the 1000px maximum width */\n            margin-left: auto; /* Centers the container */\n            margin-right: auto; /* Centers the container */\n            padding: 2.5rem 1rem; /* Vertical padding and horizontal padding for mobile safety */\n        }\n        \n        /* Enhanced Letter Header Styling */\n        .letter-header {\n            font-size: 2rem; /* Larger font size (32px) */\n            font-weight: 900;\n            line-height: 1.2;\n            color: #e5002b;\n            margin-top: 1rem;\n            margin-bottom: 0.5rem;\n            /* Underline effect for emphasis */\n            position: relative;\n            display: inline-block;\n        }\n        .letter-header::after {\n            content: '';\n            position: absolute;\n            bottom: 0;\n            left: 0;\n            width: 100%;\n            height: 4px;\n            background: linear-gradient(90deg, #e5002b 0%, rgba(229, 0, 43, 0.2) 100%);\n            border-radius: 2px;\n            transform: translateY(4px);\n        }\n\n        /* Enhanced Brand Link Styling */\n        .brand-link {\n            display: block;\n            padding: 8px 0;\n            /* CRITICAL CHANGE: Explicitly setting font size to 14px (above 13px minimum) */\n            font-size: 14px; \n            font-weight: 500;\n            color: #4b5563;\n            transition: color 0.2s, padding-left 0.2s;\n            text-decoration: none;\n            width: fit-content;\n        }\n        .brand-link:hover {\n            color: #1f2937;\n            padding-left: 5px;\n            text-decoration: none;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"list-container-1000\">\n        \n        <!-- Main Title -->\n        <h1 class=\"text-3xl md:text-4xl font-extrabold mb-10 text-center\">\n            Explore All <span class=\"text-cpg-red\">100+</span> Featured Automotive Brands\n        </h1>\n\n        <!-- Alphabetical Brand Grid Container -->\n        <div id=\"brandsList\" class=\"grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-y-2 gap-x-8\">\n            <!-- Content injected by JavaScript -->\n        </div>\n\n    </div>\n\n    <script>\n        // List of popular auto parts brands\n        const brands = [\n            'ACDelco', 'Akebono', 'Atlas', 'ARP', 'AEM Induction', 'AP Exhaust', 'Aisin', 'Auto Ventshade (AVS)', 'AWE Tuning', \n            'Bosch', 'Bendix', 'Bilstein', 'Borla Exhaust', 'Brembo Brakes', 'Beck/Arnley', 'Bully Dog', 'BFGoodrich', 'B&M Racing', \n            'Continental', 'Castrol', 'Centric Parts', 'CIPA', 'Champion', 'Crown Automotive', 'Curt Manufacturing', 'Cobb Tuning', \n            'Cosworth', 'Dorman', 'Dayco', 'Denso', 'Delphi', 'DiabloSport', 'Dunlop Tires', 'DeatschWerks', 'Eibach Springs', \n            'Exedy Clutch', 'Edelbrock', 'ECS Tuning', 'FRAM Filters', 'Fel-Pro Gaskets', 'Firestone', 'Fuzion Tires', 'Gates', \n            'GMB', 'Goodyear', 'Gabriel', 'Grant Products', 'Hawk Performance', 'Holley Performance', 'Hella', 'Husky Liners', \n            'Hypertech', 'INA', 'Injen Technology', 'Injector Dynamics', 'K&N Filters', 'KYB Shocks', 'Koni', 'Kumho Tires', \n            'KW Suspensions', 'Lucas Oil', 'LuK Clutch', 'Lisle Tools', 'MagnaFlow', 'Monroe Shocks', 'Mobil 1', 'MOOG Chassis', \n            'Motul', 'Michelin', 'Mahle', 'McLeod Racing', 'Mishimoto', 'NGK', 'Nitto Tires', 'NOS Systems', 'Neuspeed', 'Noco', \n            'OE Solutions', 'OPTIMA Batteries', 'OMP', 'OTC Tools', 'PIAA', 'Power Stop', 'Permatex', 'Pirelli', 'Pro Comp', \n            'Purolator', 'Raybestos', 'Rotella', 'Roush Performance', 'Red Line Oil', 'StopTech', 'Spectre', 'Spicer', \n            'Standard Motor Products', 'Sylvania', 'Summit Racing', 'Superchips', 'TEIN', 'Tokico', 'TruXedo', 'TYC', 'TSW Wheels', \n            'Tenneco', 'TurboSmart', 'VHT', 'VDO', 'Valvoline', 'Wagner', 'WeatherTech', 'WIX Filters', 'Zex Nitrous', 'ZF Group', \n            'Yokohama', 'Tomei', 'Sachs', 'HKS', 'AEM Electronics', 'EBC Brakes'\n        ].sort(); \n\n        const brandsListElement = document.getElementById('brandsList');\n        \n        // Group brands by their first letter\n        const brandsByLetter = brands.reduce((acc, brand) => {\n            const firstLetter = brand[0].toUpperCase();\n            if (!acc[firstLetter]) {\n                acc[firstLetter] = [];\n            }\n            acc[firstLetter].push(brand);\n            return acc;\n        }, {});\n\n        let htmlContent = '';\n        const letters = Object.keys(brandsByLetter).sort();\n\n        // Generate the HTML for the alphabetical list\n        letters.forEach(letter => {\n            htmlContent += `\n                <div class=\"list-section\">\n                    <div class=\"letter-header\">${letter}</div>\n                    ${brandsByLetter[letter].map(brand => \n                        `<a href=\"#\" class=\"brand-link\" title=\"Shop ${brand} Parts\">${brand}</a>`\n                    ).join('')}\n                </div>\n            `;\n        });\n\n        brandsListElement.innerHTML = htmlContent;\n\n    </script>\n</body>\n</html>"
      }
    },
