    "custom_liquid_h6XBAY": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Shop By Categories</title>\n\n<script src=\"https://cdn.tailwindcss.com\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap\" rel=\"stylesheet\">\n\n<style>\nbody { font-family: 'Inter', sans-serif; }\n\n.text-cpg-red { color: #e5002b; }\n.bg-cpg-red { background-color: #e5002b; }\n\n.list-container-1200 {\n    max-width: 1200px;\n    margin: auto;\n    padding: 4rem 1rem;\n}\n\n.category-card {\n    background: #fff;\n    border-radius: 12px;\n    border: 1px solid #e5e7eb;\n    min-height: 120px;\n    padding: 1rem 0;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    transition: all .3s ease;\n    text-decoration: none;\n}\n\n.category-card:hover {\n    transform: translateY(-4px);\n    box-shadow: 0 8px 15px rgba(229,0,43,.15);\n}\n\n.card-title {\n    font-size: 13px;\n    font-weight: 600;\n    padding-top: 14px;\n    text-align: center;\n}\n\n/* MOBILE: 2 columns × 3 rows */\n.collapsed {\n    max-height: 390px;\n    overflow: hidden;\n}\n\n/* TABLET: 3 columns × 3 rows */\n@media (min-width: 640px) {\n    .collapsed {\n        max-height: 390px;\n    }\n}\n\n/* DESKTOP: 6 columns × 3 rows */\n@media (min-width: 1024px) {\n    .collapsed {\n        max-height: 390px;\n    }\n}\n</style>\n</head>\n\n<body>\n\n<div class=\"list-container-1200\">\n\n<h2 class=\"text-3xl md:text-4xl font-extrabold mb-12 text-center\">\n    Shop By <span class=\"text-cpg-red\">Categories</span>\n</h2>\n\n<!-- CATEGORY GRID -->\n<div id=\"categoryGrid\"\n     class=\"grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4 collapsed transition-all duration-500\">\n\n    <!-- CATEGORY ITEMS -->\n    <a href=\"https://carpartglobal.com/collections/electrical-lighting-and-body\" class=\"category-card\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0687/6007/6332/files/Charging_Starting.svg\">\n    <div class=\"card-title\">Charging & Starting</div>\n</a>\n\n<a href=\"https://carpartglobal.com/collections/ignition\" class=\"category-card\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0687/6007/6332/files/Ignition.svg\">\n    <div class=\"card-title\">Ignition</div>\n</a>\n\n<a href=\"https://carpartglobal.com/collections/mufflers\" class=\"category-card\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0687/6007/6332/files/Mufflers.svg\">\n    <div class=\"card-title\">Mufflers</div>\n</a>\n\n<a href=\"https://carpartglobal.com/collections/belts-and-cooling\" class=\"category-card\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0687/6007/6332/files/Belts_and_Cooling.svg\">\n    <div class=\"card-title\">Belts & Cooling</div>\n</a>\n\n<a href=\"https://carpartglobal.com/collections/bumper\" class=\"category-card\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0687/6007/6332/files/Bumper.svg\">\n    <div class=\"card-title\">Bumper</div>\n</a>\n\n<a href=\"https://carpartglobal.com/collections/air-and-fuel-delivery\" class=\"category-card\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0687/6007/6332/files/Air_Fuel_Delivery.svg\">\n    <div class=\"card-title\">Air & Fuel Delivery</div>\n</a>\n\n<a href=\"https://carpartglobal.com/collections/winch\" class=\"category-card\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0687/6007/6332/files/Winch.svg\">\n    <div class=\"card-title\">Winch</div>\n</a>\n\n<a href=\"https://carpartglobal.com/collections/truck-box\" class=\"category-card\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0687/6007/6332/files/Truck_Box.svg\">\n    <div class=\"card-title\">Truck Box</div>\n</a>\n\n<a href=\"https://carpartglobal.com/collections/wheels-tires\" class=\"category-card\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0687/6007/6332/files/Wheels_Tires.svg\">\n    <div class=\"card-title\">Wheels & Tires</div>\n</a>\n\n<a href=\"https://carpartglobal.com/collections/wiper-and-washer\" class=\"category-card\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0687/6007/6332/files/Wiper_and_Washer.svg\">\n    <div class=\"card-title\">Wiper & Washer</div>\n</a>\n\n<a href=\"https://carpartglobal.com/collections/driveline-and-axles\" class=\"category-card\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0687/6007/6332/files/Driveline_and_Axles.svg\">\n    <div class=\"card-title\">Driveline & Axles</div>\n</a>\n\n<a href=\"https://carpartglobal.com/collections/brake\" class=\"category-card\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0687/6007/6332/files/Brakes.svg\">\n    <div class=\"card-title\">Brakes</div>\n</a>\n\n<a href=\"https://carpartglobal.com/collections/transmission\" class=\"category-card\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0687/6007/6332/files/Transmission.svg\">\n    <div class=\"card-title\">Transmission</div>\n</a>\n\n<a href=\"https://carpartglobal.com/collections/hvac\" class=\"category-card\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0687/6007/6332/files/HVAC.svg\">\n    <div class=\"card-title\">Batteries & Charging</div>\n</a>\n\n<a href=\"https://carpartglobal.com/collections/hvac\" class=\"category-card\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0687/6007/6332/files/Suspension.svg\">\n    <div class=\"card-title\">HVAC</div>\n</a>\n<a href=\"https://carpartglobal.com/collections/electronics-and-toys\"  class=\"category-card\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0687/6007/6332/files/Electronics.svg?v=1768492521\">\n    <div class=\"card-title\">Electronics</div>\n</a>\n<a href=\"https://carpartglobal.com/collections/steering\"  class=\"category-card\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0687/6007/6332/files/Steering.svg?v=1768492521\">\n    <div class=\"card-title\">Steering</div>\n</a>\n<a href=\"https://carpartglobal.com/collections/hardware-and-service-supplies\"  class=\"category-card\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0687/6007/6332/files/Hardware_Supplies.svg?v=1768492521\">\n    <div class=\"card-title\">Hardware & Supplies</div>\n</a>\n<a href=\"https://carpartglobal.com/collections/engine\"  class=\"category-card\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0687/6007/6332/files/Engine_Components.svg?v=1768492521\">\n    <div class=\"card-title\">Engine Components</div>\n</a>\n<a href=\"https://carpartglobal.com/collections/doors\"  class=\"category-card\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0687/6007/6332/files/Doors.svg?v=1768492521\">\n    <div class=\"card-title\">Doors</div>\n</a>\n<a href=\"https://carpartglobal.com/collections/exhaust\"  class=\"category-card\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0687/6007/6332/files/Exhaust.svg?v=1768492521\">\n    <div class=\"card-title\">Exhaust</div>\n</a>\n<a href=\"https://carpartglobal.com/collections/frame\"  class=\"category-card\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0687/6007/6332/files/Frame.svg?v=1768492521\">\n    <div class=\"card-title\">Frame</div>\n</a>\n<a href=\"https://carpartglobal.com/collections/floor\"  class=\"category-card\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0687/6007/6332/files/Floor.svg?v=1768492521\">\n    <div class=\"card-title\">Floor</div>\n</a>\n<a href=\"https://carpartglobal.com/collections/shocks-and-struts\"  class=\"category-card\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0687/6007/6332/files/Shocks_and_Struts.svg?v=1768492521\">\n    <div class=\"card-title\">Shocks And Struts</div>\n</a>\n\n</div>\n\n<!-- LOAD MORE BUTTON -->\n<div class=\"text-center mt-10\">\n<button id=\"toggleBtn\"\n    class=\"inline-flex items-center gap-2 px-10 py-3 rounded-xl bg-cpg-red text-white hover:bg-red-700 transition shadow-lg\">\n    <span id=\"btnText\">Load More Categories</span>\n    <svg id=\"btnIcon\" xmlns=\"http://www.w3.org/2000/svg\" class=\"h-5 w-5 transition-transform duration-300\"\n        fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n        <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"\n            d=\"M19 9l-7 7-7-7\" />\n    </svg>\n</button>\n</div>\n\n</div>\n\n<script>\nconst grid = document.getElementById('categoryGrid');\nconst btnText = document.getElementById('btnText');\nconst btnIcon = document.getElementById('btnIcon');\n\ndocument.getElementById('toggleBtn').addEventListener('click', () => {\n    grid.classList.toggle('collapsed');\n    const collapsed = grid.classList.contains('collapsed');\n\n    btnText.textContent = collapsed ? 'Load More Categories' : 'Show Less';\n    btnIcon.style.transform = collapsed ? 'rotate(0deg)' : 'rotate(180deg)';\n});\n</script>\n\n</body>\n</html>"
