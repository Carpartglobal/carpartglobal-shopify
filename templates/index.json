            "text": "<style>\n/* ===== TRUST SECTION ===== */\n.trust-section {\n  background: #fffffff2;\n  border: 1px solid #eee;\n  border-radius: 10px;\n  padding: 25px;\n  max-width: 1200px;\n  margin: 30px auto;\n  font-family: Arial, sans-serif;\n}\n\n.trust-top {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  flex-wrap: wrap;\n  gap: 15px;\n}\n\n.trust-help {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n}\n\n.trust-avatar {\n  width: 45px;\n  height: 45px;\n  border-radius: 50%;\n  background: #e60023;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  color: #fff;\n  font-weight: bold;\n}\n\n.trust-help-text {\n  font-size: 13px;\n}\n\n.trust-help-text a {\nfont-size: 12px;\n  color: #e60023;\n  text-decoration: underline;\n  font-weight: 600;\n}\n\n.trust-main {\n  margin-top: 15px;\n  display: flex;\n  justify-content: space-between;\n  flex-wrap: wrap;\n  gap: 20px;\n}\n\n.trust-left h2 {\n  font-size: 18px;\n  margin-bottom: 10px;\nfont-weight: 700;\n}\n\n.trust-left span {\n  color: #e60023;\n  font-weight: bold;\n}\n\n.trust-rating {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n  margin-top: 10px;\n}\n\n.stars {\n  color: #f4b400;\n  font-size: 18px;\n}\n\n.review-count {\n  font-size: 14px;\n  color: #666;\n}\n\n.trust-right {\n  max-width: 100%;\n  font-size: 14px;\n  color: #555;\n}\n\n.trust-logos {\n  margin-top: 30px;\n  display: grid;\n  grid-template-columns: repeat(4, 1fr);\n  gap: 10px;\n  align-items: center;\n}\n\n.trust-logos img {\n  max-height: 50px;\n  width: auto;\n  margin: 0 auto;\n  display: block;\n  \n}\n\n/* ===== MOBILE ===== */\n@media (max-width: 768px) {\n  .trust-main {\n    flex-direction: column;\n  }\n\n  .trust-logos {\n    grid-template-columns: repeat(2, 1fr);\n  }\n\n  .trust-left h2 {\n    font-size: 16px;\n  }\n}\n</style>\n\n<div class=\"trust-section\">\n\n  <!-- TOP HELP BAR -->\n  <div class=\"trust-top\">\n    <div class=\"trust-help\">\n      <div class=\"trust-avatar\">?</div>\n      <div class=\"trust-help-text\">\n        <strong>Have any questions?</strong><br>\n        We’re here to help. \n        <a href=\"https://carpartglobal.com/pages/contact\">Contact Us</a>\n      </div>\n    </div>\n  </div>\n\n  <!-- MAIN CONTENT -->\n  <div class=\"trust-main\">\n    <div class=\"trust-left\">\n      <h2><span>Car Part Global</span> is a trusted auto parts supplier</h2>\n\n      <div class=\"trust-rating\">\n        <div class=\"stars\">★★★★★</div>\n        <div class=\"review-count\">Trusted by thousands of auto parts customers</div>\n      </div>\n    </div>\n\n    <div class=\"trust-right\">\n      We supply high-quality auto parts with a focus on reliability, fast service, and customer satisfaction.  \n      Our goal is to provide genuine parts you can trust.\n    </div>\n  </div>\n\n  <!-- TRUST LOGOS -->\n  <div class=\"trust-logos\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0687/6007/6332/files/images_2_96a8b81b-ebd9-4282-9baf-9c19836d95e3.png?v=1769188090\" alt=\"Google\">\n   \n    <img src=\"https://cdn.shopify.com/s/files/1/0687/6007/6332/files/images_1.png?v=1769187490\" alt=\"BBB\">\n <img src=\"https://cdn.shopify.com/s/files/1/0687/6007/6332/files/Google-Review-Logo.png?v=1769187605\" alt=\"Trustpilot\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0687/6007/6332/files/592-5926866_safe-logo-safe-checkout_9536122a-1e70-44a5-8348-78f00d04b94b.png?v=1769188523\" alt=\"Secure Checkout\">\n  </div>\n\n</div>",
