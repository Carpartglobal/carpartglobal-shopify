    "custom_liquid_VRp3Th": {
      "type": "custom-liquid",
      "disabled": true,
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<!-- Vehicle Selector Component (Single File - HTML, Isolated CSS, JS) -->\n<script src=\"https://cdn.tailwindcss.com\"></script>\n\n<style>\n  /* Base style for the container */\n  .carpart-container {\n    max-width: 1200px;\n    margin: 20px auto;\n    padding: 16px;\n  }\n\n  /* Main Selector Card Styling */\n  .carpart-selector-card {\n    background-color: #ffffff;\n    border-radius: 12px;\n    padding: 24px;\n    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 4px 10px -2px rgba(0, 0, 0, 0.05);\n    border: 1px solid #e5e7eb;\n  }\n  \n  /* Heading/Status */\n  .carpart-heading {\n    font-size: 1.5rem;\n    font-weight: 700;\n    color: #1f2937;\n    margin-bottom: 0px;\n  }\n  \n  .carpart-subheading {\n    font-size: 1rem;\n    color: #4b5563;\n    margin-bottom: 0px;\n  }\n\n  /* Dropdown and Button Layout - Desktop/Tablet */\n  .carpart-grid-layout {\n    display: grid;\n    grid-template-columns: 1fr; /* Default: Single column for mobile */\n    gap: 16px; \n    align-items: end; /* Align items to the bottom */\n  }\n\n  @media (min-width: 768px) {\n    .carpart-grid-layout {\n      grid-template-columns: repeat(4, 1fr); /* 4 columns: Year, Make, Model, Search Button */\n    }\n  }\n\n  /* Select Group Container */\n  .carpart-select-group {\n    width: 100%;\n  }\n  \n  /* Labels */\n  .carpart-select-group label {\n    display: block;\n    font-size: 0.875rem; \n    font-weight: 600; \n    color: #1f2937;\n    margin-bottom: 6px;\n  }\n\n  /* Select Element Styling */\n  .carpart-select-group select {\n    width: 100%;\n    padding: 12px; \n    border: 2px solid #d1d5db; \n    border-radius: 8px; \n    box-shadow: inset 0 1px 3px rgba(0, 0, 0, 0.05);\n    background-color: #f9fafb; /* Light gray background */\n    color: #1f2937; \n    transition: all 0.2s;\n    appearance: none; /* Remove default arrow */\n    background-image: url('data:image/svg+xml;utf8,<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 20 20\" fill=\"%234b5563\"><path fill-rule=\"evenodd\" d=\"M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z\" clip-rule=\"evenodd\" /></svg>');\n    background-repeat: no-repeat;\n    background-position: right 1rem center;\n    background-size: 1.5em;\n  }\n\n  .carpart-select-group select:focus {\n    outline: none;\n    border-color: #2563eb; \n    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.5); /* Blue glow */\n  }\n\n  /* Search Button Styling */\n  .carpart-search-button {\n    background-color: #dc2626; /* Strong Red for urgency/Carpart Global theme */\n    color: white;\n    font-weight: 700; \n    padding: 12px 24px;\n    border-radius: 8px;\n    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.06);\n    transition: all 0.2s ease-in-out;\n    cursor: pointer;\n    border: none;\n    height: 100%; /* Important to match height of select fields */\n    min-height: 48px; /* Ensure minimum height */\n  }\n\n  .carpart-search-button:hover {\n    background-color: #b91c1c; \n    transform: translateY(-1px);\n    box-shadow: 0 6px 10px -2px rgba(0, 0, 0, 0.2);\n  }\n  \n  .carpart-search-button:disabled {\n      background-color: #fca5a5; /* Light red disabled state */\n      cursor: not-allowed;\n      transform: none;\n      box-shadow: none;\n  }\n</style>\n\n<div class=\"carpart-container\">\n  \n  <!-- Always Visible Vehicle Selector Card -->\n  <div class=\"carpart-selector-card\">\n    \n    <!-- Title and Current Vehicle Status -->\n    <div id=\"carpart-status-text\">\n        <div class=\"carpart-heading\">Find Parts for Your Vehicle</div>\n        <div class=\"carpart-subheading\">\n            <span id=\"carpart-current-vehicle\">No vehicle selected.</span> Select your Year, Make, and Model below.\n        </div>\n    </div>\n\n    <div class=\"carpart-grid-layout\">\n        \n      <!-- Year Dropdown -->\n      <div class=\"carpart-select-group\">\n        <label for=\"carpart-year-select\">Year</label>\n        <select id=\"carpart-year-select\" disabled>\n          <option value=\"\">Select Year</option>\n        </select>\n      </div>\n      \n      <!-- Make Dropdown -->\n      <div class=\"carpart-select-group\">\n        <label for=\"carpart-make-select\">Make</label>\n        <select id=\"carpart-make-select\" disabled>\n          <option value=\"\">Select Make</option>\n        </select>\n      </div>\n      \n      <!-- Model Dropdown -->\n      <div class=\"carpart-select-group\">\n        <label for=\"carpart-model-select\">Model</label>\n        <select id=\"carpart-model-select\" disabled>\n          <option value=\"\">Select Model</option>\n        </select>\n      </div>\n\n      <!-- Action Button (Occupies the 4th column on desktop) -->\n      <div class=\"carpart-select-group\" style=\"margin-top: 24px;\">\n        <button id=\"carpart-set-vehicle-button\" class=\"carpart-search-button\" disabled>\n          Search Products\n        </button>\n      </div>\n    </div>\n    \n  </div>\n</div>\n\n<script>\n  // --- Start: JavaScript for Vehicle Selector ---\n  \n  // Base URL for the store search.\n  const CARPART_GLOBAL_BASE_URL = 'https://carpartglobal.com';\n  \n  // Mock Data (For demonstration of dropdown functionality)\n  const carpart_vehicleData = {\n    2023: {\n      'Toyota': ['Camry', 'RAV4', 'Tacoma'],\n      'Ford': ['F-150', 'Escape', 'Explorer']\n    },\n    2022: {\n      'Toyota': ['Camry', 'Corolla'],\n      'Honda': ['CR-V', 'Civic']\n    },\n    2021: {\n      'Chevrolet': ['Silverado', 'Equinox']\n    },\n    2020: {\n      'Jeep': ['Wrangler', 'Grand Cherokee'],\n      'BMW': ['3-Series', 'X5']\n    }\n  };\n\n  // Get all DOM elements\n  const carpart_yearSelect = document.getElementById('carpart-year-select');\n  const carpart_makeSelect = document.getElementById('carpart-make-select');\n  const carpart_modelSelect = document.getElementById('carpart-model-select');\n  const carpart_setButton = document.getElementById('carpart-set-vehicle-button');\n  const carpart_currentVehicleDisplay = document.getElementById('carpart-current-vehicle');\n\n  // State to hold the selected vehicle\n  let carpart_selectedVehicle = null;\n  \n  function carpart_log(message) {\n    console.log('[CarPartGlobal Selector]', message);\n  }\n\n  // Helper function to reset and enable a dropdown\n  function carpart_resetAndEnableSelect(selectElement, defaultText) {\n    selectElement.innerHTML = `<option value=\"\">${defaultText}</option>`;\n    selectElement.disabled = false;\n  }\n  \n  // Helper function to reset and disable a dropdown\n  function carpart_resetAndDisableSelect(selectElement, defaultText) {\n    selectElement.innerHTML = `<option value=\"\">${defaultText}</option>`;\n    selectElement.disabled = true;\n  }\n  \n  // 1. Initialize Years on Load\n  function carpart_initializeYears() {\n    carpart_log('Initializing years...');\n    const years = Object.keys(carpart_vehicleData).sort((a, b) => b - a); // Sort descending\n    \n    carpart_resetAndEnableSelect(carpart_yearSelect, 'Select Year');\n    carpart_resetAndDisableSelect(carpart_makeSelect, 'Select Make');\n    carpart_resetAndDisableSelect(carpart_modelSelect, 'Select Model');\n    carpart_setButton.disabled = true;\n    \n    years.forEach(year => {\n      const option = document.createElement('option');\n      option.value = year;\n      option.textContent = year;\n      carpart_yearSelect.appendChild(option);\n    });\n    \n    carpart_yearSelect.disabled = false;\n    carpart_log('Years initialized.');\n  }\n\n  // 2. Load Makes based on Year selection\n  function carpart_loadMakes() {\n    carpart_log('Loading makes...');\n    const selectedYear = carpart_yearSelect.value;\n\n    carpart_resetAndDisableSelect(carpart_modelSelect, 'Select Model');\n    carpart_setButton.disabled = true;\n\n    if (!selectedYear) {\n      carpart_resetAndDisableSelect(carpart_makeSelect, 'Select Make');\n      carpart_updateStatus(); // Update status if year is deselected\n      return;\n    }\n\n    const makes = Object.keys(carpart_vehicleData[selectedYear]).sort();\n    carpart_resetAndEnableSelect(carpart_makeSelect, 'Select Make');\n    \n    makes.forEach(make => {\n      const option = document.createElement('option');\n      option.value = make;\n      option.textContent = make;\n      carpart_makeSelect.appendChild(option);\n    });\n    carpart_log(`Loaded ${makes.length} makes for ${selectedYear}.`);\n    carpart_updateStatus();\n  }\n\n  // 3. Load Models based on Year and Make selection\n  function carpart_loadModels() {\n    carpart_log('Loading models...');\n    const selectedYear = carpart_yearSelect.value;\n    const selectedMake = carpart_makeSelect.value;\n    \n    carpart_setButton.disabled = true;\n\n    if (!selectedMake) {\n      carpart_resetAndDisableSelect(carpart_modelSelect, 'Select Model');\n      carpart_updateStatus();\n      return;\n    }\n\n    const models = carpart_vehicleData[selectedYear][selectedMake].sort();\n    carpart_resetAndEnableSelect(carpart_modelSelect, 'Select Model');\n\n    models.forEach(model => {\n      const option = document.createElement('option');\n      option.value = model;\n      option.textContent = model;\n      carpart_modelSelect.appendChild(option);\n    });\n    \n    carpart_checkSetVehicleButton();\n    carpart_log(`Loaded ${models.length} models for ${selectedYear} ${selectedMake}.`);\n    carpart_updateStatus();\n  }\n\n  // 4. Check if the Set Vehicle button should be enabled\n  function carpart_checkSetVehicleButton() {\n    carpart_log('Checking Set Vehicle button status...');\n    const isReady = carpart_yearSelect.value && carpart_makeSelect.value && carpart_modelSelect.value;\n    carpart_setButton.disabled = !isReady;\n    \n    if (isReady) {\n        // If all three are selected, set the temporary selected vehicle for status update\n        carpart_selectedVehicle = { \n            year: carpart_yearSelect.value, \n            make: carpart_makeSelect.value, \n            model: carpart_modelSelect.value \n        };\n    } else {\n        // If selection is incomplete, clear the status so the display is accurate\n        carpart_selectedVehicle = null; \n    }\n    carpart_updateStatus();\n  }\n  \n  // 5. Trigger the search/redirect\n  function carpart_setVehicle() {\n    const year = carpart_yearSelect.value;\n    const make = carpart_makeSelect.value;\n    const model = carpart_modelSelect.value;\n\n    if (!year || !make || !model) {\n        // This should be handled by the disabled button, but as a fallback:\n        alert('Please select a Year, Make, and Model before searching.'); \n        return;\n    }\n\n    carpart_selectedVehicle = { year, make, model };\n    \n    // 1. Construct the Search Query\n    const searchQuery = `${year} ${make} ${model}`;\n    \n    // 2. Construct the full URL for your store's search page\n    const encodedQuery = encodeURIComponent(searchQuery);\n    const searchUrl = `${CARPART_GLOBAL_BASE_URL}/search?q=${encodedQuery}`;\n\n    carpart_log(`Vehicle Set: ${searchQuery}. Redirecting to: ${searchUrl}`);\n\n    // Persist the selection (optional, but good practice)\n    localStorage.setItem('carpart_selectedVehicle', JSON.stringify(carpart_selectedVehicle));\n\n    // Update the final status text\n    carpart_updateStatus();\n\n    // 3. Redirect the browser\n    window.location.href = searchUrl;\n  }\n\n  // 6. Update the visible status text\n  function carpart_updateStatus() {\n    if (carpart_selectedVehicle && carpart_yearSelect.value === carpart_selectedVehicle.year && carpart_makeSelect.value === carpart_selectedVehicle.make && carpart_modelSelect.value === carpart_selectedVehicle.model) {\n      const { year, make, model } = carpart_selectedVehicle;\n      carpart_currentVehicleDisplay.innerHTML = `\n        <span style=\"font-weight: 700; color: #10b981;\">Selected Vehicle: ${year} ${make} ${model}</span>\n      `;\n    } else if (carpart_yearSelect.value || carpart_makeSelect.value || carpart_modelSelect.value) {\n         // Show partial selection if user is in the middle of choosing\n         carpart_currentVehicleDisplay.innerHTML = `\n            <span style=\"font-weight: 500; color: #f59e0b;\">Selection in progress: ${carpart_yearSelect.value} ${carpart_makeSelect.value} ${carpart_modelSelect.value}</span>\n        `;\n    } else {\n      carpart_currentVehicleDisplay.textContent = 'No vehicle selected.';\n    }\n  }\n\n  // 7. Load persistent vehicle selection from storage\n  function carpart_loadPersistentVehicle() {\n    const storedVehicle = localStorage.getItem('carpart_selectedVehicle');\n    if (storedVehicle) {\n        try {\n            const vehicle = JSON.parse(storedVehicle);\n            // Pre-select the options if they exist in the data\n            if (vehicle.year && vehicle.make && vehicle.model) {\n                carpart_selectedVehicle = vehicle;\n                \n                // Initialize dropdowns with stored values\n                carpart_yearSelect.value = vehicle.year;\n                carpart_loadMakes(); // This will load the makes and check the button\n                carpart_makeSelect.value = vehicle.make;\n                carpart_loadModels(); // This will load the models\n                carpart_modelSelect.value = vehicle.model;\n                \n                carpart_checkSetVehicleButton(); // Final check to enable button and update status\n                carpart_log('Loaded and restored vehicle from storage.');\n                return;\n            }\n        } catch(e) {\n            carpart_log('Failed to parse stored vehicle data.');\n            localStorage.removeItem('carpart_selectedVehicle');\n        }\n    }\n    carpart_selectedVehicle = null;\n  }\n\n  // --- Main Initialization Function ---\n  function carpart_init() {\n    carpart_log('Initialization started.');\n    \n    // 1. Initialize the dropdown options\n    carpart_initializeYears();\n    \n    // 2. Try to load and pre-select a persistent vehicle\n    carpart_loadPersistentVehicle();\n    \n    // 3. Update the visible status box\n    carpart_updateStatus(); \n    \n    // 4. Attach all event listeners\n    carpart_setButton.addEventListener('click', carpart_setVehicle);\n\n    // Dropdown Change Listeners\n    carpart_yearSelect.addEventListener('change', carpart_loadMakes);\n    carpart_makeSelect.addEventListener('change', carpart_loadModels);\n    carpart_modelSelect.addEventListener('change', carpart_checkSetVehicleButton);\n    \n    carpart_log('Initialization complete. Event listeners attached.');\n  }\n\n  // Ensure the script runs after the entire DOM is loaded\n  if (document.readyState === 'loading') {\n    document.addEventListener('DOMContentLoaded', carpart_init);\n  } else {\n    carpart_init();\n  }\n\n  // --- End: JavaScript for Vehicle Selector ---\n</script>"
      }
    },
