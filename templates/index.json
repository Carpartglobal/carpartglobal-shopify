    "custom_liquid_D4Frnt": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<style>\n  .stats-section {\n    max-width: 1200px;\n    margin:auto;\n    padding: 20px;\n\n  }\n\n  .stats-grid {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 20px;\n    text-align: center;\n  }\n\n  .stat-box {\n    border: 1px solid #eee;\n    padding: 30px 15px;\n    border-radius: 8px;\n    background: #fff;\n  }\n\n  .stat-icon {\ntext-align: -webkit-center;\n    font-size: 40px;\n    color: #e5002b;\n    margin-bottom: 10px;\n  }\n\n  .stat-number {\n    font-size: 25px;\n    font-weight: 600;\n    color: #000;\n    margin: 12px 0;\n  }\n\n  .stat-title {\n    font-size: 14px;\n    font-weight: 600;\n    color: #e5002b;\n  }\n\n  /* Mobile responsive */\n  @media (max-width: 768px) {\n    .stats-grid {\n      grid-template-columns: repeat(2, 1fr);\n    }\n.stat-box {\n    border: 1px solid #eee;\n    padding: 20px 5px;\n    border-radius: 8px;\n    background: #fff;\n  }\n.stat-icon {\n    font-size: 30px;\n    color: #e5002b;\n    margin-bottom: 10px;\n  }\n .stat-number {\n    font-size: 20px;\n    font-weight: 600;\n    color: #000000;\n    margin: 5px 0;\n  }\n .stat-title {\n    font-size: 12px;\n    font-weight: 600;\n    color: #e5002b;\n  }\n  }\n\n  @media (max-width: 480px) {\n     .stats-grid {\n    gap: 10px;\n}\n .stats-section {\n    max-width: 100%;\n    margin:auto;\n    padding: 20px;\n  }\n  }\n</style>\n\n<div class=\"stats-section\">\n  <div class=\"stats-grid\">\n\n    <div class=\"stat-box\">\n      <div class=\"stat-icon\"><img src=\"https://cdn.shopify.com/s/files/1/0687/6007/6332/files/Auto_Parts.png?v=1768490135\"></div>\n      <div class=\"stat-number\">790,000+</div>\n      <div class=\"stat-title\">Auto Parts</div>\n    </div>\n\n    <div class=\"stat-box\">\n      <div class=\"stat-icon\"><img src=\"https://cdn.shopify.com/s/files/1/0687/6007/6332/files/Trusted_Brands.png?v=1768490135\"></div>\n      <div class=\"stat-number\">250+</div>\n      <div class=\"stat-title\">Trusted Brands</div>\n    </div>\n\n    <div class=\"stat-box\">\n      <div class=\"stat-icon\"><img src=\"https://cdn.shopify.com/s/files/1/0687/6007/6332/files/Vehicle_Fits.png?v=1768490135\"></div>\n      <div class=\"stat-number\">20,000+</div>\n      <div class=\"stat-title\">Vehicle Fits</div>\n    </div>\n\n    <div class=\"stat-box\">\n      <div class=\"stat-icon\"><img src=\"https://cdn.shopify.com/s/files/1/0687/6007/6332/files/itment_Accuracy.png?v=1768490134\"></div>\n      <div class=\"stat-number\">99%</div>\n      <div class=\"stat-title\">Fitment Accuracy</div>\n    </div>\n\n  </div>\n</div>"
      }
    },
    "custom_liquid_wQjxcr": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<style>\n/* ===== Department Section Wrapper ===== */\n.cpg-departments {\n  max-width: 1200px;\n  margin: 0px auto 30px auto;\n  padding: 10px;\n}\n.headin {\n    width: 1200px;\n    margin: auto;\n    text-align: -webkit-center;\n}\n.headin h2 {\n    padding-bottom: 0px!important;\n    font-weight: 600;\n    font-family: 'Montserrat';\n    font-size: 22px;\n    color: #000000;\nmargin-bottom:-10px;\n\n}\n.headin p {\n    padding-bottom: 10px;\n    font-weight: 400;\n    font-family: 'Montserrat';\n    font-size: 14px;\n}\n/* Grid */\n.cpg-department-grid {\n    display: grid;\n    grid-template-columns: repeat(9, 1fr);\n    gap: 0px;\n    justify-content: center;\n}\n\n/* Card */\n.cpg-department-item {\nwidth:124px;\n  text-decoration: none;\n  background: #ffffff;\n  border: 1px solid #e5e7eb;\n  border-radius: 8px;\n  padding: 12px 10px;\n  text-align: center;\n  transition: all 0.25s ease;\n  box-shadow: 0 4px 10px rgba(0,0,0,0.04);\n}\n\n/* Hover */\n\n\n.cpg-department-item:hover span {\n  color: #d71920;\n}\n\n/* Icon */\n.cpg-department-item img {\n    width: 152px;\n    height: 95px;\n    margin-bottom: 0px;\n    transition: transform 0.25s ease;\n    object-fit: cover;\n}\n\n.cpg-department-item:hover img {\n  transform: scale(1.08);\n}\n\n/* Text */\n.cpg-department-item span {\n  display: block;\n  font-size: 13px;\n  font-weight: 600;\n  color: #1f2937;\n  line-height: 1.2;\n}\n\n/* Tablet */\n@media (max-width: 1200px) {\n  .cpg-department-grid {\n    grid-template-columns: repeat(5, 1fr);\n  }\n}\n\n/* Mobile */\n@media (max-width: 768px) {\n  .cpg-department-grid {\n    grid-template-columns: repeat(3, 1fr);\n    gap: 0px;\n  }\n.headin {\n    width: 100%;\n    margin: auto;\n    text-align: -webkit-center;\n}\n .cpg-department-item {\n    width: 100%;\n    text-decoration: none;\n    background: #ffffff;\n    border: .5px solid #e5e7eb;\n    border-radius: 0px;\n    padding: 5px 5px;\n    text-align: center;\n    transition: all 0.25s ease;\n    box-shadow: 0 4px 10px rgba(0,0,0,0.04);\n}\n\n  .cpg-department-item img {\n    width: 100%;\n  }\n.headin h2 {\n    padding-bottom: 0px;\n    font-weight: 600;\n    font-family: 'Montserrat';\n    font-size: 18px;\n    color: #dc2626;\npadding: 0px 10px;\nmargin-bottom:-10px;\n}\n.headin p {\n    padding-bottom: 10px;\n    font-weight: 400;\n    font-family: 'Montserrat';\n    font-size: 12px;\npadding: 0px 20px;\n\n}\n  .cpg-department-item span {\n    font-size: 12px;\n  }\n}\n</style>\n<div class=\"headin\">\n<h2>Your Trusted Source for Auto Parts</h2>\n<p>At Car Part Global, we specialize in providing high-quality auto part designed to make vehicle repairs and maintenance easier than ever. With over a decade of experience in the automotive aftermarket industry, we offer a vast selection of parts at competitive prices, all backed by expert support and fast, reliable shipping. Shop with Car Part Global and experience top-tier service and seamless shopping today!</p>\n</div>\n<div class=\"cpg-departments\">\n  <div class=\"cpg-department-grid\">\n\n    <a href=\"https://carpartglobal.com/collections/brake\" class=\"cpg-department-item\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0687/6007/6332/files/Replacement_Parts.png?v=1769526387\" alt=\"\">\n      <span>Replacement Parts</span>\n    </a>\n\n    <a href=\"https://carpartglobal.com/collections/body\" class=\"cpg-department-item\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0687/6007/6332/files/Body_Parts.png?v=1769526387\" alt=\"\">\n      <span>Body Parts</span>\n    </a>\n\n    <a href=\"https://carpartglobal.com/collections/lighting-exterior\" class=\"cpg-department-item\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0687/6007/6332/files/Lighting.png?v=1769526388\" alt=\"\">\n      <span>Lightings</span>\n    </a>\n\n    <a href=\"https://carpartglobal.com/collections/vehicles-equipment-tools-and-supplies\" class=\"cpg-department-item\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0687/6007/6332/files/Tools.png?v=1769526387\" alt=\"\">\n      <span>Tools & Equipment</span>\n    </a>\n\n    <a href=\"https://carpartglobal.com/collections/exterior-accessories\" class=\"cpg-department-item\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0687/6007/6332/files/Exterior.png?v=1769526387\" alt=\"\">\n      <span>Exterior</span>\n    </a>\n\n    <a href=\"https://carpartglobal.com/collections/interior-accessories\" class=\"cpg-department-item\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0687/6007/6332/files/Interior.png?v=1769526386\" alt=\"\">\n      <span>Interior</span>\n    </a>\n\n    <a href=\"https://carpartglobal.com/collections/performance-upgrade-kit\" class=\"cpg-department-item\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0687/6007/6332/files/Performance.png?v=1769526387\" alt=\"\">\n      <span>Performance Parts</span>\n    </a>\n\n    <a href=\"https://carpartglobal.com/collections/tire\" class=\"cpg-department-item\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0687/6007/6332/files/Tires_Wheels.png?v=1769526387\" alt=\"\">\n      <span>Wheels & Tires</span>\n    </a>\n\n    <a href=\"https://carpartglobal.com/collections/sports-and-outdoors\" class=\"cpg-department-item\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0687/6007/6332/files/Specialty_Parts.png?v=1769526387\" alt=\"\">\n      <span>Specialty Parts</span>\n    </a>\n\n  </div>\n</div>"
      }
    },
