{% if section.settings.enable %}
<div class="halo-megamenu megamenu-style-6"
     data-mega-menu="{{ section.settings.nav_label | handle }}">

  <div class="megamenu-6-inner">

    <!-- LEFT GRID -->
    <div class="megamenu-6-grid">
      {% for block in section.blocks %}
        <a href="{{ block.settings.link }}" class="megamenu-6-item">
          {% if block.settings.icon %}
            <img src="{{ block.settings.icon | image_url: width: 80 }}">
          {% endif %}
          <span>{{ block.settings.label }}</span>
        </a>
      {% endfor %}
    </div>

    <!-- RIGHT IMAGES -->
    <div class="megamenu-6-side">
      {% if section.settings.image_1 %}
        <a href="{{ section.settings.image_1_link }}">
          <img src="{{ section.settings.image_1 | image_url: width: 500 }}">
        </a>
      {% endif %}
      {% if section.settings.image_2 %}
        <a href="{{ section.settings.image_2_link }}">
          <img src="{{ section.settings.image_2 | image_url: width: 500 }}">
        </a>
      {% endif %}
      {% if section.settings.image_3 %}
        <a href="{{ section.settings.image_3_link }}">
          <img src="{{ section.settings.image_3 | image_url: width: 500 }}">
        </a>
      {% endif %}
    </div>

  </div>
</div>
{% endif %}

{% schema %}
{
  "name": "Mega Menu Style 6",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable",
      "label": "Enable Mega Menu",
      "default": true
    },
    {
      "type": "text",
      "id": "nav_label",
      "label": "Navigation Label (Exact Name)",
      "info": "Example: Body"
    },
    { "type": "image_picker", "id": "image_1", "label": "Side Image 1" },
    { "type": "url", "id": "image_1_link", "label": "Image 1 Link" },

    { "type": "image_picker", "id": "image_2", "label": "Side Image 2" },
    { "type": "url", "id": "image_2_link", "label": "Image 2 Link" },

    { "type": "image_picker", "id": "image_3", "label": "Side Image 3" },
    { "type": "url", "id": "image_3_link", "label": "Image 3 Link" }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Menu Item",
      "settings": [
        { "type": "text", "id": "label", "label": "Label Name" },
        { "type": "url", "id": "link", "label": "Link" },
        { "type": "image_picker", "id": "icon", "label": "Icon Image" }
      ]
    }
  ],
  "max_blocks": 30,
  "presets": [
    { "name": "Mega Menu Style 6" }
  ]
}
{% endschema %}
