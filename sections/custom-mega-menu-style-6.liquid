{% if section.settings.enable %}
<div class="custom-mega-menu-style-6"
     data-mega-handle="{{ section.settings.menu_handle }}">
  
  <div class="container" style="max-width: 90%;">
    <div class="mega-flex">

      <!-- LEFT: 30 ITEMS -->
      <div class="mega-items">
        {% for block in section.blocks %}
          {% if block.type == 'item' %}
            <a href="{{ block.settings.link }}" class="mega-item">
              {% if block.settings.icon %}
                <img src="{{ block.settings.icon | image_url: width: 60 }}">
              {% endif %}
              <span>{{ block.settings.label }}</span>
            </a>
          {% endif %}
        {% endfor %}
      </div>

      <!-- RIGHT: 3 IMAGES -->
      <div class="mega-banners">
        {% for block in section.blocks %}
          {% if block.type == 'banner' %}
            <a href="{{ block.settings.link }}" class="banner">
              <img src="{{ block.settings.image | image_url: width: 500 }}">
            </a>
          {% endif %}
        {% endfor %}
      </div>

    </div>
  </div>
</div>
{% endif %}
{% schema %}
{
  "name": "Custom Mega Menu Style 6",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable",
      "label": "Enable Mega Menu",
      "default": true
    },
    {
      "type": "text",
      "id": "menu_handle",
      "label": "Nav Menu Name (Handle)",
      "info": "Example: regular-service"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Menu Item",
      "settings": [
        { "type": "text", "id": "label", "label": "Label Name" },
        { "type": "url", "id": "link", "label": "Link" },
        { "type": "image_picker", "id": "icon", "label": "Icon Image" }
      ]
    },
    {
      "type": "banner",
      "name": "Side Banner",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Banner Image" },
        { "type": "url", "id": "link", "label": "Banner Link" }
      ]
    }
  ],
  "max_blocks": 33,
  "presets": [
    { "name": "Custom Mega Menu Style 6" }
  ]
}
{% endschema %}
