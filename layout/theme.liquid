<script>
document.addEventListener('DOMContentLoaded', function() {
  const sidebar = document.getElementById('navigation-mobile');
  if (!sidebar) return;

  document.body.addEventListener('click', function(e) {
    const toggleBtn = e.target.closest('.mobileMenu-toggle');
    const closeBtn = e.target.closest('.halo-sidebar-close');

    if (toggleBtn) {
      e.preventDefault();
      sidebar.classList.toggle('open');
      return;
    }

    if (closeBtn) {
      e.preventDefault();
      sidebar.classList.remove('open');
      return;
    }

    if (!sidebar.contains(e.target) && !e.target.closest('.mobileMenu-toggle')) {
      sidebar.classList.remove('open');
    }
  });

  document.querySelectorAll('.mobileMenu-toggle a').forEach(a => {
    a.setAttribute('href', 'javascript:void(0)');
  });
});
</script>

<script>
document.addEventListener('DOMContentLoaded', function() {
    if (window.innerWidth > 1024) return;

    document.body.addEventListener('click', function(e) {
        const isSubLink = e.target.closest('.header__submenu a');
        if (isSubLink) {
            return;
        }

        const li = e.target.closest('.menu-lv-item.dropdown');
        const toggleIcon = e.target.closest('.icon-dropdown');

        if (li) {
            const link = li.querySelector('.menu-lv-1__action');
            const submenu = li.querySelector('ul.header__submenu');

            if (!e.target.closest('.nav-title-mobile')) {
                e.preventDefault();
                e.stopPropagation();

                const isOpen = li.classList.contains('is-open');

                const siblings = li.parentElement.querySelectorAll(':scope > .menu-lv-item.dropdown.is-open');
                siblings.forEach(openLi => {
                    if (openLi !== li) {
                        openLi.classList.remove('is-open');
                        const openSub = openLi.querySelector('ul.header__submenu');
                        if (openSub) openSub.style.display = 'none';
                    }
                });

                if (!isOpen) {
                    li.classList.add('is-open');
                    if (submenu) {
                        submenu.style.display = 'block';
                        submenu.scrollTop = 0;
                    }
                } else {
                    li.classList.remove('is-open');
                    if (submenu) submenu.style.display = 'none';
                }
            }
        }

        const backBtn = e.target.closest('.nav-title-mobile');
        if (backBtn) {
            const parentLi = backBtn.closest('.menu-lv-item.dropdown');
            if (parentLi) {
                parentLi.classList.remove('is-open');
                const sub = parentLi.querySelector('ul.header__submenu');
                if (sub) sub.style.display = 'none';
            }
        }
    });
});
</script>     

<script>
(function () {
  function closeAllPanels() {
    document.querySelectorAll(
      '#cm-garage .cm_collapsible-elem, [id^="shopify-block-"][id*="convermax_year_make_model"] .cm_collapsible-elem'
    ).forEach(function(panel) {
      panel.style.setProperty('display', 'none', 'important');
      panel.style.setProperty('height', '0', 'important');
      panel.style.setProperty('overflow', 'hidden', 'important');
    });
    document.querySelectorAll(
      '#cm-garage .cmTemplate_active, [id^="shopify-block-"][id*="convermax_year_make_model"] .cmTemplate_active'
    ).forEach(function(w) {
      w.classList.remove('is-manual-open');
    });
  }

  function togglePanel(wrapper) {
    var panel = wrapper.querySelector('.cm_collapsible-elem');
    if (!panel) return;
    var isOpen = wrapper.classList.contains('is-manual-open');
    closeAllPanels();
    if (!isOpen) {
      wrapper.classList.add('is-manual-open');
      panel.style.setProperty('display', 'block', 'important');
      panel.style.removeProperty('height');
      panel.style.removeProperty('overflow');
    }
  }

  function initToggle() {
    closeAllPanels();
    setTimeout(closeAllPanels, 100);
    setTimeout(closeAllPanels, 500);
    setTimeout(closeAllPanels, 1000);

    document.addEventListener('click', function(e) {
      var insidePanel = e.target.closest(
        '#cm-garage .cm_collapsible-elem, [id^="shopify-block-"][id*="convermax_year_make_model"] .cm_collapsible-elem'
      );
      var insideHeader = e.target.closest(
        '#cm-garage .cm_vehicle-widget_header, [id^="shopify-block-"][id*="convermax_year_make_model"] .cm_vehicle-widget_header'
      );

      if (!insidePanel && !insideHeader) {
        closeAllPanels();
        return;
      }
      if (!insideHeader) return;

      var rect = insideHeader.getBoundingClientRect();
      var clickX = e.clientX - rect.left;
      var isRightSide = clickX >= (rect.width - 50);

      if (!isRightSide) {
        e.preventDefault();
        e.stopPropagation();
        return;
      }

      e.preventDefault();
      e.stopPropagation();
      var wrapper = insideHeader.closest('.cmTemplate_active') || insideHeader.closest('.cm_vehicle-widget');
      if (wrapper) togglePanel(wrapper);
    }, true);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initToggle);
  } else {
    initToggle();
  }
})();
</script>




<script>
(function () {
  function fixConvermaxBorder() {
    var headers = document.querySelectorAll('#cm-garage .cm_vehicle-widget_header');
    headers.forEach(function (el) {
      el.style.setProperty('border', '3px solid #e5002b', 'important');
      el.style.setProperty('outline', 'none', 'important');
      el.style.setProperty('box-shadow', 'none', 'important');
      el.style.setProperty('filter', 'none', 'important');
      el.style.setProperty('background', '#fff', 'important');
    });

    var containers = document.querySelectorAll(
      '#cm-garage .cm_vehicle-widget, #cm-garage .cm_garage, #cm-garage .cm_garage__container-desktop'
    );
    containers.forEach(function (el) {
      el.style.setProperty('border', 'none', 'important');
      el.style.setProperty('outline', 'none', 'important');
      el.style.setProperty('box-shadow', 'none', 'important');
    });
  }

  function initConvermaxBorderFix() {
    fixConvermaxBorder();

    var root = document.body;
    if (!root) return;

    var observer = new MutationObserver(function () {
      fixConvermaxBorder();
    });

    observer.observe(root, {
      childList: true,
      subtree: true,
      attributes: true,
      attributeFilter: ['style', 'class']
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initConvermaxBorderFix);
  } else {
    initConvermaxBorderFix();
  }
})();
document.querySelectorAll("footer a")
.forEach(function(link) {
    link.style.setProperty("text-decoration", "none", "important");
});
</script>
